spawn(function()
    while true do
        if env.SqaysConfig.AutoOpenCapsule then
            local capsuleType = env.SqaysConfig.CapsuleType
            local cost = CapsuleCosts[capsuleType] or math.huge
            local zone = CapsuleLocations[capsuleType]
            local char = player.Character

            if not (char and char:FindFirstChild("HumanoidRootPart")) then
                task.wait(0.5)
            elseif not zone then
                warn("[Capsule] Zone not set for " .. capsuleType)
                task.wait(2)
            else
                local prism = _getCurrencyAmount("Prism") or 0
                if env.SqaysConfig.CapsuleCheckPrism and prism < cost then
                    warn("[Capsule] Not enough Prism: " .. prism .. " < " .. cost)
                    task.wait(1)
                else
                    if env.SqaysConfig.CapsulePauseMining then
                        env.SqaysConfig.AutoRollTier = false
                        task.wait(0.1)
                    end

                    local minePos = char:GetPivot()
                    char:PivotTo(CFrame.new(zone))
                    task.wait(env.SqaysConfig.CapsuleZoneWait)

                    local before = _getCurrencyAmount("Prism") or 0
                    pcall(function()
                        local MainRemote = getMainRemote()
                        if MainRemote then
                            MainRemote:FireServer("OpenCapsule", capsuleType)
                        end
                    end)
                    task.wait(env.SqaysConfig.CapsuleReturnWait)
                    local after = _getCurrencyAmount("Prism") or 0

                    char:PivotTo(minePos)

                    if env.SqaysConfig.CapsulePauseMining then
                        env.SqaysConfig.AutoRollTier = true
                    end

                    if after < before then
                        warn("[Capsule] Opened " .. capsuleType .. " (Prism -" .. tostring(before - after) .. ")")
                    else
                        warn("[Capsule] No Prism decrease - increase Zone Wait or check zone")
                    end

                    task.wait(env.SqaysConfig.CapsuleCycleCooldown)
                end
