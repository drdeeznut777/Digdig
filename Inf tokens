-- Universal HTTP request fallback (Wave, Synapse Z, Xeno, Codex, Vega X, Delta, Solara)
local function httpGet(url)
    local success, result = pcall(function()
        -- Delta Executor için öncelik
        if http and http.request then
            return http.request({Url = url, Method = "GET"}).Body
        elseif game.HttpGet then
            return game:HttpGet(url)
        elseif syn and syn.request then
            return syn.request({Url = url, Method = "GET"}).Body
        elseif request then
            return request({Url = url, Method = "GET"}).Body
        elseif http_request then
            return http_request({Url = url, Method = "GET"}).Body
        end
    end)
    if success and result then
        return result
    end
    return nil
end

-- Universal clipboard fallback
local function setClipboard(text)
    local success = pcall(function()
        if setclipboard then
            setclipboard(text)
        elseif syn and syn.write_clipboard then
            syn.write_clipboard(text)
        elseif clipboard and clipboard.set then
            clipboard.set(text)
        elseif toclipboard then
            toclipboard(text)
        end
    end)
    return success
end

-- Universal threading (task.spawn for modern executors, coroutine.wrap for older)
local function spawn(func)
    if task and task.spawn then
        return task.spawn(func)
    else
        return coroutine.wrap(func)()
    end
end

-- Universal wait function
local function wait(duration)
    if task then
        task.wait(duration)
    else
        wait(duration)
    end
end

