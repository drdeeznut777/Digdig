    Increment = 0.05,
    CurrentValue = env.SqaysConfig.HarvestSpeed,
    Callback = function(v)
        env.SqaysConfig.HarvestSpeed = v
    end
})

Tab:CreateToggle({
    Name = "Auto Roll Tier",
    CurrentValue = env.SqaysConfig.AutoRollTier,
    Callback = function(v)
        env.SqaysConfig.AutoRollTier = v
    end
})

Tab:CreateToggle({
    Name = "Anti AFK",
    CurrentValue = env.SqaysConfig.AntiAFK,
    Callback = function(v)
        env.SqaysConfig.AntiAFK = v
        setAntiAFK(v)
    end
})

